#!/bin/sh
### BEGIN INIT INFO
# Provides:          tsd-{{.Role}}
# Required-Start:    $network $remote_fs
# Should-Start:      tailscale
# Required-Stop:     $network $remote_fs
# Should-Stop:       tailscale
# Default-Start:     2 3 4 5
# Default-Stop:      0 1 6
# Short-Description: Tailscale Metrics Discovery — {{.Role}}
# Description:       {{.Description}}
### END INIT INFO

set -e

DAEMON="{{.BinaryPath}}"
PIDFILE="/var/run/tsd-{{.Role}}.pid"
CONFIG="{{.ConfigFile}}"

. /lib/lsb/init-functions

case "$1" in
    start)
        log_daemon_msg "Starting tsd-{{.Role}}" "tsd-{{.Role}}"
        $DAEMON {{.Role}} daemon --config "$CONFIG" > /dev/null 2>&1 &
        echo $! > $PIDFILE
        log_end_msg 0
        ;;
    stop)
        log_daemon_msg "Stopping tsd-{{.Role}}" "tsd-{{.Role}}"
        if [ -f $PIDFILE ]; then
            kill $(cat $PIDFILE) 2>/dev/null || true
            rm $PIDFILE
        fi
        log_end_msg 0
        ;;
    status)
        if [ -f $PIDFILE ]; then
            if kill -0 $(cat $PIDFILE) 2>/dev/null; then
                log_success_msg "tsd-{{.Role}} is running"
                exit 0
            fi
        fi
        log_failure_msg "tsd-{{.Role}} is not running"
        exit 1
        ;;
    restart)
        $0 stop
        $0 start
        ;;
    *)
        echo "Usage: $0 {start|stop|restart|status}"
        exit 1
        ;;
esac

exit 0
