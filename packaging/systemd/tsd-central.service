[Unit]
Description=Tailscale Metrics Discovery — Central
After=network.target
Wants=tailscaled.service

[Service]
Type=simple
ExecStart=/usr/bin/tsd central daemon --config /etc/tsd/central.toml
Restart=on-failure
RestartSec=5s
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
